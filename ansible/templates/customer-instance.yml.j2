# Customer Uptime Kuma instance manifest
# Rendered by playbooks/provision-customer.yml and committed to a
# GitOps Gitea repo. Argo CD picks it up and reconciles into the
# cluster - one namespace per customer.
#
# Variables (set by the playbook):
#   customer_name       - lowercase slug, [a-z0-9-]{3,32}
#   customer_email      - contact email, used for audit + commit msg
#   admin_password      - Uptime Kuma admin password for this customer
#   customer_domain     - optional; if set, the kuma image auto-creates
#                          an HTTPS monitor for https://<domain> on boot
#   provisioned_by      - "sales" (customer-instances repo) or
#                          "ops"   (test-customers repo)
#   k3s_server_ip       - inherited from group_vars/all.yml
#   gitea_http_port     - inherited from group_vars/all.yml
#   gitea_org           - inherited from group_vars/all.yml
---
apiVersion: v1
kind: Namespace
metadata:
  name: customer-{{ customer_name }}
  labels:
    app: orange-kuma
    customer: {{ customer_name }}
    provisioned-by: {{ provisioned_by }}
  annotations:
    orange-kuma/customer-email: "{{ customer_email }}"
---
apiVersion: v1
kind: Secret
metadata:
  name: kuma-admin
  namespace: customer-{{ customer_name }}
  labels:
    app: orange-kuma
    customer: {{ customer_name }}
type: Opaque
stringData:
  UPTIME_KUMA_ADMIN_PASSWORD: "{{ admin_password }}"
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: kuma-data
  namespace: customer-{{ customer_name }}
  labels:
    app: orange-kuma
    customer: {{ customer_name }}
spec:
  accessModes: [ReadWriteOnce]
  storageClassName: longhorn
  resources:
    requests:
      storage: 1Gi
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: kuma
  namespace: customer-{{ customer_name }}
  labels:
    app: orange-kuma
    customer: {{ customer_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: orange-kuma
      customer: {{ customer_name }}
  template:
    metadata:
      labels:
        app: orange-kuma
        customer: {{ customer_name }}
    spec:
      enableServiceLinks: false
      containers:
        - name: kuma
          image: {{ k3s_server_ip }}:{{ gitea_http_port }}/{{ gitea_org }}/orange-uptime-kuma:latest
          ports:
            - name: http
              containerPort: 3001
          env:
            - name: UPTIME_KUMA_PORT
              value: "3001"
            - name: CUSTOMER_NAME
              value: "{{ customer_name }}"
            - name: CUSTOMER_EMAIL
              value: "{{ customer_email }}"
            # When set, the kuma image auto-creates an HTTPS monitor for
            # this domain on startup (idempotent). Empty = no monitor.
            - name: CUSTOMER_DOMAIN
              value: "{{ customer_domain | default('') }}"
            - name: UPTIME_KUMA_ADMIN_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: kuma-admin
                  key: UPTIME_KUMA_ADMIN_PASSWORD
          volumeMounts:
            - name: kuma-data
              mountPath: /app/data
      volumes:
        - name: kuma-data
          persistentVolumeClaim:
            claimName: kuma-data
---
apiVersion: v1
kind: Service
metadata:
  name: kuma
  namespace: customer-{{ customer_name }}
  labels:
    app: orange-kuma
    customer: {{ customer_name }}
spec:
  type: ClusterIP
  selector:
    app: orange-kuma
    customer: {{ customer_name }}
  ports:
    - name: http
      port: 3001
      targetPort: 3001
---
# Per-customer Ingress: exposes this customer's Uptime Kuma at
#   https://{{ customer_name }}.{{ domain_suffix }}
# through the cluster ingress-nginx controller (LoadBalancer on host
# port 443). nip.io resolves the host to {{ k3s_server_ip }} automatically,
# so no external DNS is required. TLS is served with ingress-nginx's default
# self-signed certificate (no tls block here on purpose).
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: kuma
  namespace: customer-{{ customer_name }}
  labels:
    app: orange-kuma
    customer: {{ customer_name }}
spec:
  ingressClassName: nginx
  rules:
    - host: {{ customer_name }}.{{ domain_suffix }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: kuma
                port:
                  number: 3001
---
# Deny ingress from all other customer-* namespaces. Traffic from
# non-customer namespaces is still allowed (the "customer DoesNotExist"
# rule), which is what lets the ingress-nginx controller in the
# ingress-nginx namespace reach this Service. The effect is that each
# customer's Uptime Kuma is reachable via the platform ingress but never
# from a different customer's pod.
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: deny-cross-customer
  namespace: customer-{{ customer_name }}
  labels:
    app: orange-kuma
    customer: {{ customer_name }}
spec:
  podSelector: {}
  policyTypes: [Ingress]
  ingress:
    - from:
        - namespaceSelector:
            matchExpressions:
              - key: customer
                operator: DoesNotExist
        - namespaceSelector:
            matchLabels:
              customer: {{ customer_name }}
